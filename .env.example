# ── Frontend (Vite) — copy to repo root `.env` ───────────────────────────────
# Never put Stripe secret keys or Spotify client secrets here.

# Supabase (public anon key only — copy from Supabase → Project Settings → API)
VITE_SUPABASE_URL=https://rltejlyhvhlivskbezkx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Spotify — client ID only (PKCE OAuth in browser; safe to expose). Must be prefixed VITE_ so Vite bundles it.
# Netlify: add VITE_SPOTIFY_CLIENT_ID (not SPOTIFY_CLIENT_ID alone — that is ignored by the frontend build).
# In Spotify Dashboard → Redirect URIs, add the site origin (no path) — the app uses window.location.origin:
#   http://localhost:5173   (local Vite; use 5174 etc. if that port is busy)
#   https://streamenginev1.netlify.app   (or your custom domain)
# Do not use /callback unless you implement that path; PKCE returns to the site root with ?code=
VITE_SPOTIFY_CLIENT_ID=a689918def2f448e9632819a8ec289cd

# Stripe — publishable key only (safe in browser). Must be from the same Stripe account as
# STRIPE_SECRET_KEY in server/.env (same Dashboard → Developers → API keys).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Public app URL — use the exact URL Vite prints (default http://localhost:5173; may be 5174+ if 5173 is busy).
VITE_APP_URL=http://localhost:5173

# Optional branding
VITE_APP_NAME=StreamEngine

# Backend API is proxied from Vite: `/api` → see vite.config.js (default localhost:3333).
# For Netlify / static hosting (no Vite proxy), set your deployed API origin at build time:
# VITE_API_ORIGIN=https://your-api.example.com
# On the API server, set APP_URL (or CORS_ALLOW_ORIGINS) to match this frontend URL so Stripe + /api calls succeed.
# Server secrets (Stripe secret, Spotify secret, OpenAI, service role) belong in server/.env — see server/.env.example
