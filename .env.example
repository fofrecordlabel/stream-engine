# ── Frontend (Vite) — copy to repo root `.env` ───────────────────────────────
# Never put Stripe secret keys or Spotify client secrets here.

# Supabase (public anon key only)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Spotify — client ID only (PKCE OAuth in browser; safe to expose)
# In Spotify Dashboard → Redirect URIs, add exactly: http://localhost:5173/ (matches Vite strictPort)
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id

# Stripe — publishable key only (safe in browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Public app URL — use the exact URL Vite prints (default http://localhost:5173; may be 5174+ if 5173 is busy).
VITE_APP_URL=http://localhost:5173

# Optional branding
VITE_APP_NAME=StreamEngine

# Backend API is proxied from Vite: `/api` → see vite.config.js (default localhost:3333).
# Server secrets (Stripe secret, Spotify secret, OpenAI, service role) belong in server/.env — see server/.env.example
