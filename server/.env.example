# ── Backend only — copy to server/.env (never commit real values) ───────────
# Loaded by server/index.js from this directory. Root `.env` may fill missing non-secret keys if present.

# HTTP port — must match Vite dev proxy in ../vite.config.js (default 3333)
PORT=3333

# App URL for Stripe redirect URLs (success/cancel) — must match the URL Vite prints when you run npm run dev
APP_URL=http://localhost:5173

# Optional: comma-separated browser origins allowed to call this API (split hosting: Netlify + API on Render/Railway).
# Defaults: localhost + origin of APP_URL. Add extras if frontend URL differs from APP_URL.
# CORS_ALLOW_ORIGINS=https://your-app.netlify.app

# Spotify Web API (server-only; used for track/playlist metadata via Client Credentials)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Stripe (secret key never goes in frontend)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: Stripe Price ID (price_…) for recurring “Pro” plan — enables /api/create-subscription-checkout + 7-day trial
STRIPE_SUBSCRIPTION_PRICE_ID=

# Supabase admin (service role — server only)
# Same project as the app (Settings → API → Project URL)
SUPABASE_URL=https://rltejlyhvhlivskbezkx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (server route /api/ai/streamengine)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
